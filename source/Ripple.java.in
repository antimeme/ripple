/**
 * Entry point for the Ripple JAR.  When this is the main-class in the
 * manifest, it is possible to access the main method of any other
 * class by entering its name as the first command line argument.
 * There are some additional utilities provided in this class itself.
 * Run with no arguments to see available commands. */
public class Ripple {

    /** Release version of the Ripple package as a printable string. */
    public static final String VERSION = "@VERSION@";

    /**
     * Release version of the Ripple package as a decimal number.
     *
     * @return a decimal representation of the version number.
     *         Note that patch level (if any) is omitted */
    public static double getVersion()
    {
        double result = 0.0;
        String vv = VERSION;
        int point = vv.indexOf('.');
        if (point >= 0) {
            point = vv.indexOf('.', point + 1);
            if (point >= 0)
                vv = vv.substring(0, point);
        }
        try { result = Double.valueOf(vv); }
        catch (NumberFormatException ex) { }
        return result;
    }

    /**
     * Extract the contents of an InputStream.
     *
     * @param stream source of bytes
     * @return byte array containing stream contents
     * @throws IOException if the InputStream does */
    public static byte[] readAllBytes(InputStream stream)
        throws IOException
    {
        // Java 9: return stream.readAllBytes();
        ByteArrayOutputStream baos = new ByteArrayOutputStream();
        byte[] buffer = new byte[4096];
        int count;

        while ((count = stream.read(buffer)) != -1)
            baos.write(buffer, 0, count);
        return baos.toByteArray();
    }

    /**
     * Read an input stream line by line, ignoring blank lines and
     * comments (deliniated by a leading # character).
     *
     * @param in stream to read lines from
     * @return each non-blank, non-comment line */
    public static List<String> readLines(InputStream in)
    {
        List<String> result = new ArrayList<>();
        if (in == null)
            return result;
        try (BufferedReader lines = new BufferedReader
             (new InputStreamReader(in))) {
            String line;
            while ((line = lines.readLine()) != null) {
                line = line.trim();
                if ((line.length() == 0) || line.startsWith("#"))
                    continue;
                result.add(line);
            }
        } catch (IOException ex) {}
        return result;
    }

    /**
     * Collect all a URL for each JAR file in the .lib directory of
     * the JAR containing this class.
     * @return a URL for each embedded JAR */
    protected static URL[] findLibraries() {
        URL mainJAR = Ripple.class.getProtectionDomain()
            .getCodeSource().getLocation();

        List<URL> libraries = new ArrayList<>();
        for (String libraryPath : readLines
                 (Ripple.class.getResourceAsStream("/.libs"))) {
            if (!libraryPath.endsWith(".jar"))
                continue;
            try {
                URL libURL = new URL
                    ("jar:" + mainJAR.toExternalForm() +
                     "!/" + libraryPath);
                System.out.println("DEBUG " + libURL.toString());
                libraries.add(libURL);
            } catch (MalformedURLException ex) {
                ex.printStackTrace(System.err);
            }
        }
        return libraries.toArray(new URL[0]);
    }

    /**
     * Because Java can gather class files directly from a web server
     * there is no practical way to list all the classes in a package.
     * Rather than require delegate classes to be explicitly listed
     * here the build process generates a text file with all class
     * names which is read in and used to guide introspection.
     *
     * @return a fully qualified calss name for anything with a
     *         plausible looking main method */
    private static List<String> getCommands() throws Exception {
        List<String> result = new ArrayList<>();
        for (String command : readLines
                 (Ripple.class.getResourceAsStream("/.classes"))) {
            try {
                Class<?> clazz = Class.forName(command);
                Method method = clazz.getMethod("main", String[].class);
                if (Modifier.isStatic(method.getModifiers()))
                    result.add(command);
            } catch (ClassNotFoundException ex) { /* skip */
            } catch (NoSuchMethodException ex) { /* skip */ }
        }
        return result;
    }

    /**
     * Convert a byte array to a hexidecimal string for display.
     *
     * @param data byte array to encode
     * @return encoded form of input data */
    public static String hexEncode(byte[] data)
    {
        final String hex = "0123456789abcdef";
        StringBuffer out = new StringBuffer();
        for (int ii = 0; ii < data.length; ii++)
            out.append(hex.charAt((data[ii] >> 4) & 0xF)).
                append(hex.charAt(data[ii] & 0xF));
        return out.toString();
    }

    /**
     * Convert a hexidecimal string to a byte array.  Digits and
     * letters 'a' through 'f' are accepted.  White space and colon
     * characters are ignored.  Other characters result in an
     * IllegalArgumentException.
     *
     * @param data value to be decoded
     * @return a decoded byte array */
    public static byte[] hexDecode(String data)
    {
        ByteArrayOutputStream baos = new ByteArrayOutputStream();
        byte current = 0;
        boolean low = false;
        char[] data_array = data.toCharArray();
        for (int i = 0; i < data_array.length; i++) {
            char c = Character.toLowerCase(data_array[i]);
            int value = 0;
            if ((c >= '0') && (c <= '9'))      value = c - '0';
            else if ((c >= 'a') && (c <= 'f')) value = c - 'a' + 10;
            else if ((c == ':') || Character.isWhitespace(c))
                continue;
            else throw new IllegalArgumentException
                     ("Unrecognized hexidecimal character '" + c + "'");

            if (low) {
                current = (byte)(current | value);
                baos.write(current);
            } else current = (byte)(value << 4);
            low = !low;
        }
        return baos.toByteArray();
    }

    /**
     * Convert a byte array to a Base64 string for display.
     *
     * @param data byte array to encode
     * @return encoded form of input data */
    public static String base64Encode(byte[] data)
    {
        final String b64 = "ABCDEFGHIJKLMNOPQRSTUVWXYZ" +
            "abcdefghijklmnopqrstuvwxyz" + "0123456789" + "+/";
        StringBuilder out = new StringBuilder();
        for (int pos = 0; pos < data.length; pos += 3) {
            int aa = data[pos] & 0xFF;
            int bb = (pos + 1 < data.length) ?
                (data[pos + 1] & 0xFF) : 0;
            int cc = (pos + 2 < data.length) ?
                (data[pos + 2] & 0xFF) : 0;
            out.append(b64.charAt(aa >> 2));
            out.append(b64.charAt(((aa & 0x03) << 4) | (bb >> 4)));
            out.append((pos + 1 < data.length) ?
                       b64.charAt(((bb & 0x0F) << 2) |
                                  ((cc >> 6) & 0x03)) : '=');
            out.append((pos + 2 < data.length) ?
                       b64.charAt(cc & 0x3F) : '=');
        }
        return out.toString();
    }

    /**
     * Convert a Base64 encoded string to a byte array.  Alphanumeric
     * characters, plus and slash are valid.  White space is ignored.
     * Other characters result in an IllegalArgumentException.  No
     * characters other than white space or more '=' characters are
     * permitted after the first '=' character.
     *
     * @param data value to be decoded
     * @return a decoded byte array */
    public static byte[] base64Decode(String data) {
        ByteArrayOutputStream baos = new ByteArrayOutputStream();
        byte[] values = new byte[3];
        boolean terminated = false;
        int pos = 0;
        for (char c : data.toCharArray()) {
            if (Character.isWhitespace(c))
                continue;
            if (terminated) {
                if (c == '=')
                    continue;
                else throw new IllegalArgumentException
                         ("Invalid characters after termination mark");
            } else if (c == '=') {
                if (pos < 2)
                    throw new IllegalArgumentException
                        ("Padding with too few input characters");
                pos--; // discards partially decoded padding byte
                baos.write(values, 0, pos);
                terminated = true;
                continue;
            }

            int b = 0;
            if ((c >= 'A') && (c <= 'Z'))      b = c - 'A';
            else if ((c >= 'a') && (c <= 'z')) b = c - 'a' + 26;
            else if ((c >= '0') && (c <= '9')) b = c - '0' + 26 + 26;
            else if (c == '+')                 b = 62;
            else if (c == '/')                 b = 63;
            else throw new IllegalArgumentException
                     ("Invalid Base64 character \'" + c + "\'.");

            if (pos == 0)
                values[0] = (byte)(0xFC & (b << 2));
            else if (pos == 1) {
                values[0] |= (byte)(0x0F & (b >> 4));
                values[1] = (byte)(0xF0 & (b << 4));
            } else if (pos == 2) {
                values[1] |= (byte)(0x0F & (b >> 2));
                values[2] = (byte)(0xC0 & (b << 6));
            } else if (pos == 3)
                values[2] |= (byte)(0x3F & b);
            if (++pos == 4)
                baos.write(values, pos = 0, values.length);
        }
        return baos.toByteArray();
    }

    /**
     * Performs word wrapping to break up long lines.
     *
     * @param out PrintStream to send output to
     * @param start how many characters have already been written
     * @param indent spaces with which to start a new line
     * @param limit maximum number of characters in a line
     * @param value String to print with line warpping
     * @return PrintStream used for output to support cascades */
    public static PrintStream wrap
        (PrintStream out, int start, int indent, int limit,
         String value)
    {
        int written = 0;
        while (written < value.length()) {
            int clip = written;
            if (value.length() - written > limit - start) {
                int pos = written;
                boolean inWord = false;
                for (; pos < value.length(); pos++)
                    if (Character.isWhitespace(value.charAt(pos))) {
                        if ((pos > written + limit - start) &&
                            (clip > written))
                            break;
                        if (inWord)
                            clip = pos;
                        inWord = false;
                    } else inWord = true;
                if (clip == written)
                    clip = value.length();
            } else clip = value.length();
            start = indent;

            out.println(value.substring(written, clip));
            written = clip + 1;
            if (written < value.length())
                for (int i = 0; i < start; i++)
                    out.print(" ");
        }
        return out;
    }

    /**
     * Collect a password from the command line without echo.
     *
     * @param prompt explains to user which pass phrase is required
     * @return pass phrase provided by the command line user */
    public static char[] passwdPrompt(String prompt)
    {
        System.err.print(prompt);
        System.err.flush();
        return System.console().readPassword();
    }

    /** Displays a single command with word wrapped usage message. */
    private static void helpCommand
        (PrintStream o, String command, String usage, int maxlen)
    {
        o.print("  ");
        o.print(command);
        for (int i = command.length(); i < maxlen; i++)
            o.print(" ");
        o.print(" - ");
        wrap(o, maxlen + 5, maxlen + 5, 72, usage);
    }

    /**
     * Prints a detailed usage message to the specified stream.
     *
     * @param o Usage message is sent to this stream.
     * @return Zero on success, non-zero if something went wrong.
     * @throws Exception Anything can happen. */
    public static int help(PrintStream o) throws Exception
    {
        List<String> commands = getCommands();
        String[][] internals = {
            { "test",      "Perform automated unit tests." },
            //{ "url",       "Break down URLs to see parts." },
            //{ "property",  "Display Java system property values." },
            { "hexEncode", "Convert argument strings to hex." },
            { "hexDecode", "Display the contents of argument " +
              "hex strings." },
            { "b64Encode", "Convert argument strings to base64." },
            { "b64Decode", "Display the contents of argument " +
              "base64 strings." },
        };

        wrap(o, 0, 0, 72, "A collection of simple tools as well as " +
             "a dispatch system for accessing the main method of " +
             "internal classes.");
        o.println();
        o.println("Commands:");
        int maxlen = 0;
        for (String command : commands)
            try {
                int lastDot = command.lastIndexOf('.');
                Class<?> c = Class.forName(command);
                Method m = c.getMethod("usageLine");
                String cname = (lastDot < 0) ? command :
                    command.substring(lastDot + 1).toLowerCase();
                if (cname.length() > maxlen)
                    maxlen = cname.length();
            } catch (NoSuchMethodException ex) { /* undocumented */ }
        for (String[] internal : internals)
            if (internal[0].length() > maxlen)
                maxlen = internal[0].length();

        for (String[] internal : internals)
            helpCommand(o, internal[0], internal[1], maxlen);
        for (String command : commands)
            try {
                int lastDot = command.lastIndexOf('.');
                Class<?> clazz = Class.forName(command);
                Method method = clazz.getMethod("usageLine");
                String cname = (lastDot < 0) ? command :
                    command.substring(lastDot + 1).toLowerCase();
                helpCommand(o, cname, method.invoke(null).toString(),
                            maxlen);
            } catch (InvocationTargetException ex) {
                ex.getCause().printStackTrace(o);
            } catch (NoSuchMethodException ex) { /* undocumented */ }
        return 0;
    }

    /**
     * Performs tests of this library
     * @return result of running tests
     * @throws Exception anything can happen */
    public static boolean test() throws Exception
    {
        boolean result = true;
        byte[] input = new byte[256];
        for (int index = 0; index < input.length; ++index)
            input[index] = (byte)index;

        Map<byte[], String> hextests =
            new LinkedHashMap<byte[], String>();
        hextests.put
            (input,
             "000102030405060708090a0b0c0d0e0f1011121314151617" +
             "18191a1b1c1d1e1f202122232425262728292a2b2c2d2e2f" +
             "303132333435363738393a3b3c3d3e3f4041424344454647" +
             "48494a4b4c4d4e4f505152535455565758595a5b5c5d5e5f" +
             "606162636465666768696a6b6c6d6e6f7071727374757677" +
             "78797a7b7c7d7e7f808182838485868788898a8b8c8d8e8f" +
             "909192939495969798999a9b9c9d9e9fa0a1a2a3a4a5a6a7" +
             "a8a9aaabacadaeafb0b1b2b3b4b5b6b7b8b9babbbcbdbebf" +
             "c0c1c2c3c4c5c6c7c8c9cacbcccdcecfd0d1d2d3d4d5d6d7" +
             "d8d9dadbdcdddedfe0e1e2e3e4e5e6e7e8e9eaebecedeeef" +
             "f0f1f2f3f4f5f6f7f8f9fafbfcfdfeff");

        for (byte[] decoded : hextests.keySet()) {
            String encoded = hexEncode(decoded);
            String expected = hextests.get(decoded).toLowerCase();
            if (!(expected.equals(encoded.toLowerCase()))) {
                wrap(System.out, 0, 0, 72,
                     "ERROR: expected " + expected);
                wrap(System.out, 0, 0, 72,
                     "       received " + encoded);
                result = false;
            } else if (!Arrays.equals(decoded, hexDecode(encoded))) {
                wrap(System.out, 0, 0, 72,
                     "ERROR: input mismatch");
                result = false;
            }
        }

        Map<byte[], String> b64tests =
            new LinkedHashMap<byte[], String>();
        b64tests.put
            (input,
             "AAECAwQFBgcICQoLDA0ODxAREhMUFRYXGBkaGxwdHh8gISIjJC" +
             "UmJygpKissLS4vMDEyMzQ1Njc4OTo7PD0+P0BBQkNERUZHSElK" +
             "S0xNTk9QUVJTVFVWV1hZWltcXV5fYGFiY2RlZmdoaWprbG1ub3" +
             "BxcnN0dXZ3eHl6e3x9fn+AgYKDhIWGh4iJiouMjY6PkJGSk5SV" +
             "lpeYmZqbnJ2en6ChoqOkpaanqKmqq6ytrq+wsbKztLW2t7i5ur" +
             "u8vb6/wMHCw8TFxsfIycrLzM3Oz9DR0tPU1dbX2Nna29zd3t/g" +
             "4eLj5OXm5+jp6uvs7e7v8PHy8/T19vf4+fr7/P3+/w==");
        for (byte[] decoded : b64tests.keySet()) {
            String encoded = base64Encode(decoded);
            String expected = b64tests.get(decoded).toLowerCase();
            if (!(expected.equals(encoded.toLowerCase()))) {
                wrap(System.out, 0, 0, 72,
                     "ERROR: expected " + expected);
                wrap(System.out, 0, 0, 72,
                     "       received " + encoded);
                result = false;
            } else if (!Arrays.equals(decoded, base64Decode(encoded))) {
                wrap(System.out, 0, 0, 72,
                     "ERROR: input mismatch");
                result = false;
            }
        }

        return result;
    }
    
    /**
     * Command line utility to hex encode arguments
     * @param args things to encode
     * @return zero unless something went wrong */
    public static int task_hexencode(String[] args) {
        int result = 0;
        if (args.length <= 1)
            wrap(System.out, 0, 0, 72, "Specify values to encode");
        for (int ii = 1; ii < args.length; ++ii)
            try {
                System.out.printf
                    ("%s :: %s\n", args[ii], hexEncode
                     (args[ii].getBytes("utf-8")));
            } catch (UnsupportedEncodingException ex) {
                System.out.printf("%s :: ERROR\n", args[ii]);
            }
        return result;
    }

    /**
     * Command line utility to hex decode arguments
     * @param args things to decode
     * @return zero unless something went wrong */
    public static int task_hexdecode(String[] args) {
        int result = 0;
        if (args.length <= 1)
            wrap(System.out, 0, 0, 72, "Specify values to encode");
        for (int ii = 1; ii < args.length; ++ii)
            try {
                System.out.printf("%s :: %s\n", args[ii], new String
                                  (hexDecode(args[ii]), "utf-8"));
            } catch (UnsupportedEncodingException ex) {
                System.out.printf("%s :: ERROR\n", args[ii]);
            }
        return result;
    }

    /**
     * Command line utility to base64 encode arguments
     * @param args things to encode
     * @return zero unless something went wrong */
    public static int task_b64encode(String[] args) {
        int result = 0;
        if (args.length <= 1)
            wrap(System.out, 0, 0, 72, "Specify values to encode");
        for (int ii = 1; ii < args.length; ++ii)
            try {
                System.out.println(args[ii] + " :: " + base64Encode
                                   (args[ii].getBytes("utf-8")));
            } catch (UnsupportedEncodingException ex) {
                System.out.printf("%s :: ERROR\n", args[ii]);
            }
        return result;
    }

    /**
     * Command line utility to base64 decode arguments
     * @param args things to decode
     * @return zero unless something went wrong */
    public static int task_b64decode(String[] args) {
        int result = 0;
        if (args.length <= 1)
            wrap(System.out, 0, 0, 72, "Specify values to encode");
        for (int ii = 1; ii < args.length; ++ii)
            try {
                System.out.printf("%s :: %s\n", args[ii], new String
                                  (base64Decode(args[ii]), "utf-8"));
            } catch (UnsupportedEncodingException ex) {
                System.out.printf("%s :: ERROR\n", args[ii]);
            }
        return result;
    }

    /**
     * Command line utility to execute unit tests for other classes
     * @param args ignored
     * @return zero unless something went wrong
     * @throws Exception anything can happen */
    public static int task_test(String[] args) throws Exception {
        int result = 0;
        int block = 1;
        int total = 0;
        int skips = 0;
        List<String> failures = new ArrayList<String>();
        List<String> tests = Arrays.asList(args);

        if (args.length <= 1) {
            tests = new ArrayList<>();
            for (String command : readLines
                     (Ripple.class.getResourceAsStream("/.classes"))) {
                try {
                    Class<?> clazz = Class.forName(command);
                    Method method = clazz.getMethod("test");
                    if (Modifier.isStatic(method.getModifiers()))
                        tests.add(command);
                } catch (ClassNotFoundException ex) { /* skip */
                } catch (NoSuchMethodException ex) { /* skip */ }
            }
            block = 0;
        }

        for (String command: tests) {
            if (block > 0) { --block; continue; }
            ++total;
            try {
                Class<?> clazz = Class.forName(command);
                Method method = clazz.getMethod("test");
                System.out.println(">>> BEGIN: " + command);
                boolean success = false;
                try { success = (boolean)method.invoke(null); }
                catch (InvocationTargetException ex)
                    { ex.getCause().printStackTrace(System.err); }

                if (!success)
                    failures.add(command);
                System.out.printf
                    ("    %s: %s\n",
                     (success ? "PASS" : "FAIL"), command);
            } catch (ClassNotFoundException ex) {
                System.err.println("No test for class: " + command);
            } catch (NoSuchMethodException ex) {
                System.err.println("Missing test: " + command);
            }
        }
        System.out.printf("RESULTS: %d total %d errors %d skipped\n",
                          total, failures.size(), skips);
        if (skips > 0)
            System.out.println
                ("Classes with no test() method are skipped.");
        if (failures.size() > 0) {
            for (String failure: failures)
                System.out.println("  FAILED: " + failure);
            result = 1;
        }
        return result;
    }

    /**
     * Command line utility to break down uniform resource locators
     * (URLs) into components.
     * @param args URLs to break down
     * @return zero unless something went wrong
     * @throws Exception anything can happen */
    public static int task_url(String[] args) throws Exception {
        for (int ii = 1; ii < args.length; ++ii) {
            URL url = new URL(args[ii]);
            System.out.printf("URL: %s\n", args[ii]);
            System.out.printf("  Protocol: %s\n", url.getProtocol());
            System.out.printf("  Authority: %s\n", url.getAuthority());
            System.out.printf("  Host: %s\n", url.getHost());
            System.out.printf("  Port: %d (Default: %d)\n",
                              url.getPort(), url.getDefaultPort());
            System.out.printf("  UserInfo: %s\n", url.getUserInfo());
            System.out.printf("  File: %s\n", url.getFile());
            System.out.printf("  Path: %s\n", url.getPath());
            System.out.printf("  Query: %s\n", url.getQuery());
            System.out.printf("  Reference: %s\n", url.getRef());
        }
        return 0;
    }

    /**
     * Command line utility to inspect Java system property values.
     * @param args properties to report
     * @return zero unless something went wrong */
    public static int task_property(String[] args) {
        if (args.length <= 1) {
            wrap(System.out, 0, 0, 72, "Specify one system " +
                 "property per command line argument.");
            System.out.println();
            wrap(System.out, 0, 0, 72, "<system-property> " +
                 "(example: p:java.home)");
        }
        for (int ii = 1; ii < args.length; ++ii) {
            String value = System.getProperty(args[ii]);
            System.out.print(args[ii]);
            System.out.print(" => ");
            if (value == null)
                System.out.println("null");
            else System.out.printf("\"%s\"\n", value);
        }
        return 0;
    }

    /**
     * Create a constant byte array with the contents of one or
     * more files specified by command line arguments.
     * @param args file names to open
     * @return zero unless something went wrong
     * @throws Exception anything can happen */
    public static int task_bytearray(String[] args) throws Exception {
        int perline = 8;

        for (int ii = 1; ii < args.length; ++ii) {
            String name = args[ii];
            int last = args[ii].lastIndexOf('/');

            if (last + 1 == name.length()) {
                continue;
            } else if (last >= 0)
                name = name.substring(last);
            name = name.replaceAll("[^a-zA-Z0-9]", "_");

            byte[] data = null;
            try (InputStream fis = new FileInputStream(args[ii])) {
                data = readAllBytes(fis);
            }

            System.out.printf
                ("protected static final byte[] %s = {", name);
            for (int jj = 0; jj < data.length; ++jj)
                System.out.printf("%s 0x%02X,", ((jj % perline) == 0) ?
                                  "\n   " : "", data[jj]);
            System.out.printf("%s};\n", ((data.length % perline) == 0) ?
                              "" : "\n");
        }
        return 0;
    }

    protected static Method getTask(String name) {
        Method result = null;
        try {
            result = Ripple.class.getMethod
                ("task_" + name.toLowerCase(), String[].class);
        } catch (NoSuchMethodException ex) {}
        return result;
    }

    /**
     * Entry point that dispatches requests to applications.
     * The first argument determines which capability is executed.
     *
     * @param args Command line parameters.
     * @throws Throwable Anything can happen. */
    public static void main(String[] args) throws Throwable
    {
        int result = 0;
        Method task = null;
        System.out.printf("Ripple %s - Copyright (C) 2007-2026 " +
                          "@PACKAGE_BUGREPORT@\n", VERSION);

        if (args.length == 0) {
            result = help(System.out);
        } else if ((task = getTask(args[0])) != null) {
            try {
                result = (int)task.invoke(null, new Object[] { args });
            } catch (InvocationTargetException ex) {
                ex.getCause().printStackTrace(System.err);
            }
        } else {
            String request = args[0].toLowerCase();
            for (String command : getCommands()) {
                int lastDot = command.lastIndexOf('.');
                String cname = (lastDot < 0) ? command :
                    command.substring(lastDot + 1).toLowerCase();
                if (cname.equals(request)) {
                    request = command;
                    break;
                }
            }

            try {
                String[] subargs = new String[args.length - 1];
                Class<?> clazz = Class.forName(request);
                Method method = clazz.getMethod
                    ("main", subargs.getClass());
                for (int ii = 1; ii < args.length; ++ii)
                    subargs[ii - 1] = args[ii]; 
                method.invoke(null, new Object[] { subargs });
            } catch (ClassNotFoundException ex) {
                System.err.println("No such command: " + request);
            } catch (NoSuchMethodException ex) {
                System.err.println("Missing command: " + request);
            } catch (InvocationTargetException ex) {
                throw ex.getCause();
            }
        }
        if (result != 0)
            System.exit(result);
    }
}
